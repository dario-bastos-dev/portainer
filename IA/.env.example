# 
# 1. BANCO DE DADOS (PostgreSQL Externo)
# 
DB_HOST=192.168.1.100 # IP ou host do seu Postgres
DB_PORT=5432
DB_DATABASE=dify
DB_USERNAME=seu_usuario_postgres
DB_PASSWORD=sua_senha_postgres

# 
# 2. REDIS (Interno do Swarm)
# 
REDIS_PASSWORD=uma_senha_forte_para_o_redis

# 
# 3. BANCO VETORIAL (Qdrant Externo)
# 
QDRANT_URL=http://192.168.1.101:6333 # IP ou host do seu Qdrant
QDRANT_API_KEY=sua_chave_api_do_qdrant # Deixe vazio se não usar

# 
# 4. STORAGE (MinIO Externo)
# 
S3_ENDPOINT=http://192.168.1.102:9000 # IP ou host do seu MinIO
S3_BUCKET_NAME=dify
S3_ACCESS_KEY=sua_access_key_do_minio
S3_SECRET_KEY=sua_secret_key_do_minio
S3_REGION=us-east-1 # Padrão para MinIO

# 
# 5. E-MAIL (SMTP)
# 
SMTP_SERVER=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USERNAME=seu_usuario_smtp
SMTP_PASSWORD=sua_senha_smtp
SMTP_USE_TLS=true

# 
# 7. LIMITES E SEGURANÇA
# 
UPLOAD_FILE_SIZE_LIMIT=15 # Limite em MB
UPLOAD_FILE_BATCH_LIMIT=5 # Quantidade de arquivos por vez
WEB_API_CORS_ALLOW_ORIGINS=* # Permite widgets em qualquer site

# 
# 8. TELEMETRIA E MONITORAMENTO
# 
SENTRY_DSN= # Coloque sua URL do Sentry aqui, ou deixe vazio

# 
# 9. CHAVES INTERNAS DO DIFY
# 
# Gere chaves aleatórias seguras para estes campos (ex: openssl rand -base64 42)
SECRET_KEY=gere_uma_chave_aleatoria_aqui
INIT_PASSWORD=senha_padrao_admin
PLUGIN_DAEMON_KEY=gere_outra_chave_aleatoria
INNER_API_KEY=gere_mais_uma_chave_aleatoria

# 
# 10. URLs DA APLICAÇÃO
# 
CONSOLE_WEB_URL=dify.seudominio.com.br
CONSOLE_API_URL=api.dify.seudominio.com.br
APP_URL=chat.dify.seudominio.com.br
API_URL=api.chat.dify.seudominio.com.br