# =============================================================================
# CONFIGURAÇÕES DO POSTGRES
# =============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=sua_senha_segura_postgres_aqui

# =============================================================================
# CONFIGURAÇÕES DA MARIADB
# =============================================================================
MARIADB_USER=root
MARIADB_PASSWORD=sua_senha_segura_mariadb_aqui

# =============================================================================
# CONFIGURAÇÕES DO BASEROW
# =============================================================================
BASEROW_PUBLIC_URL=baserow.<YOUR_DOMAIN>

# =============================================================================
# CONFIGURAÇÕES DO QDRANT
# =============================================================================
DOMAIN=qdrant.<YOUR_DOMAIN>
QDRANT_API_KEY=sua_chave_api_qdrant_aqui
QDRANT_READ_ONLY_API_KEY=sua_chave_api_leitura_qdrant_aqui

# =============================================================================
# CONFIGURAÇÕES DA SUPABASE
# =============================================================================

############
# Secrets
############

# Domínio principal
DOMAIN=seudominio.com.br

############
# Postgres Configuration (EXTERNO)
############

POSTGRES_HOST=seu-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=supabase
POSTGRES_PASSWORD=sua-senha-postgres-super-segura

############
# PostgREST URL (seu serviço REST externo)
############

# URL do seu serviço PostgREST externo (usado pelo Storage)
POSTGREST_URL=http://seu-postgrest-host:3000

############
# JWT Configuration
############

# Gere com: openssl rand -base64 32
JWT_SECRET=sua-chave-jwt-super-secreta-aqui
JWT_EXPIRY=3600

############
# API Keys
############

# Gere em: https://supabase.com/docs/guides/self-hosting/docker#generating-api-keys
# Ou use o gerador JWT com o JWT_SECRET acima

ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

############
# Dashboard Credentials
############

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=sua-senha-dashboard-segura

############
# Encryption Keys
############

# Gere com: openssl rand -base64 32
SECRET_KEY_BASE=sua-secret-key-base-super-longa-e-segura

# Gere com: openssl rand -base64 32
VAULT_ENC_KEY=sua-vault-encryption-key-segura

############
# Logflare Tokens
############

# Gere com: openssl rand -base64 32
LOGFLARE_PUBLIC_ACCESS_TOKEN=seu-token-publico-logflare
LOGFLARE_PRIVATE_ACCESS_TOKEN=seu-token-privado-logflare

############
# API Configuration
############

SUPABASE_PUBLIC_URL=https://supabase.${DOMAIN}
API_EXTERNAL_URL=https://supabase.${DOMAIN}
SITE_URL=https://app.${DOMAIN}
ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://localhost:8080

############
# Auth Configuration
############

DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

############
# Email Configuration (SMTP)
############

SMTP_ADMIN_EMAIL=admin@${DOMAIN}
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app-gmail
SMTP_SENDER_NAME=Supabase

MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

############
# Studio Configuration
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
OPENAI_API_KEY=

############
# Storage Configuration
############

IMGPROXY_ENABLE_WEBP_DETECTION=true

############
# Functions Configuration
############

FUNCTIONS_VERIFY_JWT=false

############
# Pooler Configuration
############

POOLER_TENANT_ID=realtime-dev
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=5
POOLER_PROXY_PORT_SESSION=5432
POOLER_PROXY_PORT_TRANSACTION=6543

############
# Docker Configuration
############

DOCKER_SOCKET_LOCATION=/var/run/docker.sock