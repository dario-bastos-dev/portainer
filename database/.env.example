# =============================================================================
# CONFIGURAÇÕES DO POSTGRES
# =============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=sua_senha_segura_postgres_aqui

# =============================================================================
# CONFIGURAÇÕES DA MARIADB
# =============================================================================
MARIADB_USER=root
MARIADB_PASSWORD=sua_senha_segura_mariadb_aqui

# =============================================================================
# CONFIGURAÇÕES DO BASEROW
# =============================================================================
BASEROW_PUBLIC_URL=baserow.<YOUR_DOMAIN>

# =============================================================================
# CONFIGURAÇÕES DO QDRANT
# =============================================================================
DOMAIN=qdrant.<YOUR_DOMAIN>
QDRANT_API_KEY=sua_chave_api_qdrant_aqui
QDRANT_READ_ONLY_API_KEY=sua_chave_api_leitura_qdrant_aqui

# =============================================================================
# CONFIGURAÇÕES DA SUPABASE
# =============================================================================
# Domínios para o Traefik
SUPABASE_STUDIO_DOMAIN=studio.seu-dominio.com
SUPABASE_API_DOMAIN=api.seu-dominio.com

# Banco de Dados (Configurações internas do Supabase)
POSTGRES_PORT=5432
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PASSWORD=sua_senha_segura_postgres_aqui

# Segurança e JWT (Segredos devem ter no mínimo 32 caracteres)
JWT_SECRET=sua_jwt_secret_longa_e_aleatoria_aqui
PG_META_CRYPTO_KEY=sua_pg_meta_crypto_key_longa_e_aleatoria_aqui
ANON_KEY=seu_anon_key_jwt_gerado_com_jwt_secret_aqui
SERVICE_ROLE_KEY=seu_service_role_key_jwt_gerado_com_jwt_secret_aqui

# Dashboard Admin (Kong)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=sua_senha_segura_para_dashboard_aqui

# API e Dashboard (Studio / PostgREST)
PGRST_DB_SCHEMAS=public,storage,graphql_public
STUDIO_DEFAULT_ORGANIZATION=Minha Org
STUDIO_DEFAULT_PROJECT=Meu Projeto
OPENAI_API_KEY=sua_chave_openai_opcional_aqui

# Autenticação (Auth / GoTrue)
SITE_URL=https://sua-app-frontend.com
ADDITIONAL_REDIRECT_URLS=
DISABLE_SIGNUP=false
JWT_EXPIRY=3600
ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_EMAIL_AUTOCONFIRM=false

# SMTP (Configurações de E-mail para Auth)
SMTP_ADMIN_EMAIL=admin@seu-dominio.com
SMTP_HOST=smtp.seu-servidor.com
SMTP_PORT=587
SMTP_USER=seu_usuario_smtp
SMTP_PASS=sua_senha_smtp
SMTP_SENDER_NAME=Supabase Auth
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# Storage
GLOBAL_S3_BUCKET=supabase-storage
STORAGE_TENANT_ID=stub
REGION=us-east-1
IMGPROXY_AUTO_WEBP=true

# Analytics / Logs (Logflare & Vector)
# LOGFLARE_PUBLIC_ACCESS_TOKEN=seu_token_publico_logflare_aqui
# LOGFLARE_PRIVATE_ACCESS_TOKEN=seu_token_privado_logflare_aqui

# Realtime / Supavisor / Secrets Base
# SECRET_KEY_BASE=sua_secret_key_base_longa_aqui
# VAULT_ENC_KEY=sua_vault_enc_key_longa_aqui

# Edge Functions
# SUPABASE_PUBLISHABLE_KEY=sua_publishable_key_aqui
# SUPABASE_SECRET_KEY=sua_secret_key_aqui
# FUNCTIONS_VERIFY_JWT=true

# Pooler (Supavisor)
# POOLER_PROXY_PORT_TRANSACTION=6543
# POOLER_TENANT_ID=stub
# POOLER_DEFAULT_POOL_SIZE=20
# POOLER_MAX_CLIENT_CONN=100
# POOLER_DB_POOL_SIZE=20
